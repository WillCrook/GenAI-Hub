    {
      "id": "prompt-critical-reading",
      "type": "prompt",
      "title": "Critically review a source",
      "summary": "Use a structured prompt to test the strength of an argument.",
      "author": {
        "name": "Dr Amina Shah",
        "organisation": "University of Bath",
        "course": "",
        "yearOfStudy": ""
      },
      "datePublished": "2026-06-30",
      "dateUpdated": "2026-07-17",
      "librarySection": "community",
      "skillAreas": [
        "academic"
      ],
      "tags": [
        "critical-thinking",
        "study"
      ],
      "featured": true,
      "mainCarousel": true,
      "published": true,
      "estimatedMinutes": null,
      "thumbnail": {
        "src": "",
        "alt": ""
      },
      "content": {
        "purpose": "Evaluate claims and evidence",
        "promptText": "Review the following argument. Identify its central claim, supporting evidence, assumptions, and plausible counterarguments.\n\nArgument: [paste text here]",
        "platforms": [
          "ChatGPT",
          "Microsoft Copilot"
        ],
        "modelsTested": [
          "GPT-5",
          "o3"
        ],
        "reasoningMode": "either",
        "usageNotes": "Verify important claims against the original source; do not treat the response as authoritative."
      }
    },
    {
      "id": "workflow-research-question",
      "type": "workflow",
      "title": "Develop a research question",
      "summary": "Move from a broad interest to a focused, testable research question.",
      "author": {
        "name": "Learning and Teaching",
        "organisation": "University of Bath",
        "course": "",
        "yearOfStudy": ""
      },
      "datePublished": "2026-06-19",
      "dateUpdated": "2026-07-18",
      "librarySection": "community",
      "skillAreas": [
        "academic"
      ],
      "tags": [
        "research",
        "planning"
      ],
      "featured": true,
      "mainCarousel": true,
      "published": true,
      "estimatedMinutes": 25,
      "thumbnail": {
        "src": "",
        "alt": ""
      },
      "content": {
        "goal": "Produce one focused research question",
        "steps": [
          {
            "stepNumber": 1,
            "title": "Define the topic",
            "description": "Write the topic, intended audience, and the decision or problem the research should inform."
          },
          {
            "stepNumber": 2,
            "title": "Test the scope",
            "description": "Check whether the question is answerable with the available time, methods, and evidence."
          },
          {
            "stepNumber": 3,
            "title": "Refine and verify",
            "description": "Rewrite the question, then ask a tutor or peer to challenge its assumptions."
          }
        ],
        "reflection": "Record what changed and which assumptions still need evidence.",
        "estimatedTotalMinutes": 25,
        "complexityScore": 3
      }
    },
